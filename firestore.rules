rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the caller has role 'admin' or 'superuser'.
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superuser'];
    }

    // Returns true if the caller has role 'superuser'.
    function isSuperuser() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superuser';
    }

    // Bookings
    // - Anyone can read and create bookings (guests book without auth)
    // - Anyone can delete guest bookings
    // - Members can delete their own member bookings
    // - Authenticated users can update bookings (migration: reassign guest → member)
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if true;
      allow delete: if resource.data.type == 'guest'
                    || (resource.data.type == 'member'
                        && request.auth != null
                        && request.auth.uid == resource.data.ownerUid);
      allow update: if request.auth != null;
    }

    // User profiles
    // - Authenticated users can read any profile
    // - Users can write their own profile
    // - Superusers can update any profile (e.g. role changes)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if isSuperuser();
    }

    // App settings
    // - All authenticated users can read (controls UI for all users)
    // - Admins and superusers can write
    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
