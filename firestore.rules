rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the caller has role 'admin' or 'superuser'.
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superuser'];
    }

    // Returns true if the caller has role 'superuser'.
    function isSuperuser() {
      return request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superuser';
    }

    function hasBookingSlotLocks() {
      return request.resource.data.slotLocks is list
        && request.resource.data.slotLocks.size() > 0
        && request.resource.data.slotLocks.size() <= 2;
    }

    function isClientBookingCreate() {
      return !request.resource.data.keys().hasAny(['ladderId']);
    }

    // Bookings
    // - Anyone can read and create bookings (guests book without auth)
    // - Anyone can delete guest bookings
    // - Members can delete their own member bookings
    // - Authenticated users can update bookings (migration: reassign guest → member)
    //
    // NOTE: settings/app.bookingEnabled and ladders/<id>.tournamentStartsAt are
    // enforced client-side only (HomePage / StegenPage / AiConfirmationCard
    // hide the UI; LadderService.createLadderMatch throws before write). This
    // matches the existing trust model — bookings are public-creatable and
    // the toggle is a "we are closed" sign, not a hard lockdown.
    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if hasBookingSlotLocks() && isClientBookingCreate();
      allow delete: if resource.data.type == 'guest'
                    || (resource.data.type == 'member'
                        && request.auth != null
                        && (request.auth.uid == resource.data.ownerUid
                            || request.auth.uid == resource.data.playerAId
                            || request.auth.uid == resource.data.playerBId));
      allow update: if request.auth != null;
    }

    // Deterministic 15-minute slot locks written in the same transaction as
    // bookings. The client transaction prevents honest concurrent writers from
    // creating overlaps; the booking rule above blocks legacy creates without
    // lock metadata.
    match /bookingSlotDays/{date} {
      allow read: if true;
      allow create, update: if true;
    }

    // User profiles
    // - Authenticated users can read any profile
    // - Users can write their own profile
    // - Superusers can update any profile (e.g. role changes)
    match /users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
      allow update: if isSuperuser();
    }

    // App settings
    // - Anyone can read (guests need bookingEnabled to respect admin toggle)
    // - Admins and superusers can write
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Ladder
    // - Authenticated users can read
    // - Admins can create, delete, and update anything
    // - Member ladder mutations (join, pause, challenge results, profile
    //   snapshot refresh) are owned by callable Cloud Functions.
    match /ladders/{ladderId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isAdmin();
    }
  }
}
